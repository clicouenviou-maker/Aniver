{
  "entities": {
    "RSVP": {
      "title": "RSVP",
      "description": "A guest's response to the invitation.",
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "description": "Guest's first name"
        },
        "lastName": {
          "type": "string",
          "description": "Guest's last name"
        },
        "attending": {
          "type": "boolean",
          "description": "Whether the guest is attending"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the RSVP was submitted"
        }
      },
      "required": ["firstName", "lastName", "attending", "createdAt"]
    }
  },
  "firestore": {
    "/rsvps/{rsvpId}": {
      "schema": {
        "$ref": "#/entities/RSVP"
      },
      "description": "Collection of RSVPs"
    }
  }
}
